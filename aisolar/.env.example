# =============================================================================
# AISolar — Environment Variables
# =============================================================================
# Copy this file to `.env` (for local dev) or set in Vercel/Supabase dashboard.
# NEVER commit the real `.env` file. See docs/SECRETS.md for rotation runbook.
#
# Variables prefixed with VITE_ are exposed to the client bundle. Everything
# else is server-only (Supabase Edge Functions, pg_cron, etc.).
# =============================================================================

# ---------- CLIENT-SIDE (Vite bundles these into the JS) ----------
# Supabase project URL and anon key. The anon key is safe to expose — RLS
# protects all data. Get these from: Supabase Dashboard → Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ID
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-KEY

# Mapbox (installer map view). Get from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=YOUR-MAPBOX-TOKEN

# v3: Demo mode toggle. Set to "true" ONLY on staging/preview builds.
# Production MUST leave this unset (or "false"). Demo mode bypasses auth
# for internal review — never enable on a public-facing deployment.
VITE_ENABLE_DEMO=false

# ---------- SERVER-SIDE (Supabase Edge Functions + pg_cron) ----------
# These are set via `supabase secrets set KEY=value` or the dashboard.
# NEVER prefix with VITE_ — they must not appear in the client bundle.

# Supabase service role key — full DB access. Used by edge functions + agents.
# Rotate immediately if leaked. Stored in Supabase Vault for pg_cron access.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Supabase anon key (server-side copy, for auth verification in edge functions).
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Allowed CORS origins (comma-separated). v3: no more wildcard.
ALLOWED_ORIGINS=https://aisolar.ie,https://www.aisolar.ie,https://staging.aisolar.ie

# ---------- STRIPE ----------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR-STRIPE-SECRET
# Webhook signing secret. Get from: https://dashboard.stripe.com/webhooks
# CRITICAL: if this is unset, the v3 webhook handler returns 500 (not silent accept).
STRIPE_WEBHOOK_SECRET=whsec_YOUR-WEBHOOK-SECRET

# ---------- COINBASE COMMERCE (crypto payments) ----------
# Get from: https://commerce.coinbase.com/dashboard/settings
COINBASE_COMMERCE_API_KEY=YOUR-COINBASE-API-KEY
# Webhook signing secret. v3: now verified via HMAC-SHA256.
COINBASE_WEBHOOK_SECRET=YOUR-COINBASE-WEBHOOK-SECRET

# ---------- POSTMARK (email) ----------
# Get from: https://account.postmarkapp.com
POSTMARK_SERVER_TOKEN=YOUR-POSTMARK-SERVER-TOKEN
# Must be verified in Postmark: Sender Signatures or Domains.
POSTMARK_SENDER_EMAIL=hello@aisolar.ie

# ---------- LOVABLE AI GATEWAY (bill extraction, proposal drafting) ----------
# Get from: https://lovable.dev (or your AI gateway provider)
LOVABLE_API_KEY=YOUR-LOVABLE-API-KEY

# ---------- SITE ----------
# The public URL of this deployment. Used for email redirects, Stripe success URLs.
SITE_URL=https://aisolar.ie

# ---------- OPTIONAL: Sentry (error tracking) ----------
# Get from: https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- OPTIONAL: Slack alerts ----------
# Webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_ALERT_WEBHOOK=
